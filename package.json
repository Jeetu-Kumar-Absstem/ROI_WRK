{
  "name": "psa-comparison-tool",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint src --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "export:pdf:liquid": "node scripts/export-pdf.mjs --tab=psa-vs-liquid --out=exports/Report-PSA_Vs_Liquid.pdf",
    "export:pdf:cylinders": "node scripts/export-pdf.mjs --tab=psa-vs-cylinders --out=exports/Report-PSA_Vs_Cylinders.pdf",
    "export:pdf:anypsa": "node scripts/export-pdf.mjs --tab=psa-vs-any-psa --out=exports/Report-PSA_Vs_Any_PSA.pdf"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.244.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-to-print": "^3.1.1",
    "recharts": "^2.8.0",
    "resend": "^6.10.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^8.41.0",
    "@types/node": "^24.7.1",
    "@types/react": "^18.0.37",
    "@types/react-dom": "^18.0.11",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.38.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.3.4",
    "globals": "^13.20.0",
    "playwright": "^1.56.0",
    "postcss": "^8.4.24",
    "tailwindcss": "^3.3.2",
    "typescript": "^5.0.2",
    "typescript-eslint": "^0.0.1-alpha.0",
    "vite": "^4.3.9"
  }
}
